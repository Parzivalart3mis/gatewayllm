# Cloud Run deployment settings. Copy to .env.cloud and fill in.
# .env.cloud is gitignored — never commit real credentials.
#
# The deploy script reads this file and passes everything to `gcloud run deploy`.

# --- GCP target ------------------------------------------------------------
GCP_REGION=us-central1
SERVICE_NAME=gatewayllm

# --- provider keys (at least one) ------------------------------------------
OPENAI_API_KEY=sk-...
GROQ_API_KEY=gsk_...
GEMINI_API_KEY=

# --- managed stores --------------------------------------------------------
# Upstash: the rediss:// URL (TLS). go-redis parses it directly.
REDIS_URL=rediss://default:...@...upstash.io:6379

# Qdrant Cloud: cluster URL + API key.
QDRANT_URL=https://xyz.aws.cloud.qdrant.io:6333
QDRANT_API_KEY=...

# Neon: pooled connection string, sslmode=require.
POSTGRES_URL=postgres://user:pass@...neon.tech/gatewayllm?sslmode=require

# --- embeddings (hosted, since the sidecar does not run on Cloud Run) -------
EMBED_KIND=api
EMBEDDER_URL=https://api.openai.com/v1
EMBED_MODEL=text-embedding-3-small
# Must match the model above and the Qdrant collection. 3-small = 1536.
VECTOR_SIZE=1536

# --- single-port host settings ---------------------------------------------
METRICS_ADDR=inline

# --- tracing (optional; empty = disabled) ----------------------------------
OTLP_ENDPOINT=

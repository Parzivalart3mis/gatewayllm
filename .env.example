# Copy to .env and fill in. Never commit .env.
#
# Only the providers you actually route to need keys; config validation will
# tell you exactly which are missing at startup.

OPENAI_API_KEY=sk-...
GROQ_API_KEY=gsk_...
GEMINI_API_KEY=...

# Embedder: "sidecar" runs the local Python model (no per-token cost, nothing
# leaves the host); "api" calls a hosted endpoint instead.
EMBED_KIND=sidecar

# Grafana admin password for the local stack.
GRAFANA_PASSWORD=admin

LOG_LEVEL=info
